# Postgres connection (same live schema the Azure Functions backend used).
DB_HOST=cosmosdb1.postgres.database.azure.com
DB_PORT=5432
DB_NAME=Pump_Selector_and_testing
DB_USER=REPLACE_WITH_DB_USER
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_SSLMODE=require

# JWT signing secret — must be a long random string. Tokens are HS256, so any
# secret shared with an existing deployment stays compatible.
JWT_SECRET=REPLACE_WITH_ANY_LONG_RANDOM_STRING

# Optional: enables the AI gap-suggestions in the selection report. If unset or
# left as the REPLACE_ placeholder, those fields simply stay "Not available".
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_API_KEY
